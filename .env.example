# Database Configuration
# Example Postgres URL:
# DATABASE_URL=postgresql://username:password@host:5432/receipts
# Example SQLite URL:
# DATABASE_URL=sqlite:////absolute/path/to/receipts.db
DATABASE_URL=sqlite:////absolute/path/to/receipts.db

# Gemini Configuration
GOOGLE_API_KEY=your-google-api-key
GEMINI_MODEL=gemini-2.5-flash-lite

# Application Config
APP_ENV=development
LOG_LEVEL=info

# Google OAuth (Gmail)
GOOGLE_OAUTH_CLIENT_ID=your-google-client-id
GOOGLE_OAUTH_CLIENT_SECRET=your-google-client-secret
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:8000/api/google/callback

# Fernet encryption key
# Generate with:
# python - <<'PY'
# from cryptography.fernet import Fernet
# print(Fernet.generate_key().decode())
# PY
FERNET_KEY=your-fernet-key

# Firebase Admin
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_SERVICE_ACCOUNT_PATH=/absolute/path/to/firebase-service-account.json
# Or provide the entire JSON as a single-line string instead:
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}
FIREBASE_FIRESTORE_TOKENS_COLLECTION=google_credentials
FIREBASE_USERS_COLLECTION=users
FIREBASE_TRANSACTIONS_COLLECTION=transactions
FIREBASE_VENDORS_COLLECTION=vendors

# Firebase Web Config for frontend runtime loading
FIREBASE_WEB_API_KEY=your-firebase-web-api-key
FIREBASE_WEB_AUTH_DOMAIN=your-project.firebaseapp.com
FIREBASE_WEB_APP_ID=your-firebase-web-app-id
# Optional:
FIREBASE_WEB_MEASUREMENT_ID=G-XXXXXXXXXX
